{
  "name": "react-qa-service",
  "private": true,
  "version": "0.0.0",
  "description": "FastAPI ReAct QA Service with RAG agent and React frontend",
  "scripts": {
    "lint": "python -m ruff check .",
    "lint:fix": "python -m ruff check . --fix",
    "format": "python -m black .",
    "format:check": "python -m black . --check",
    "typecheck": "python -m mypy app",
    "test": "python -m pytest -q",
    "test:auth": "python -m pytest -q tests/test_auth.py",
    "test:chat": "python -m pytest -q tests/test_chat.py",
    "test:watch": "ptw --runner \"python -m pytest -q\"",
    "test:coverage": "python -m pytest --cov=app --cov-report=term-missing --cov-report=html",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky install || exit 0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.0"
  }
}

